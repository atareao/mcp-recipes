# PostgreSQL con pgvector
PGHOST=pgvector.one.belcar.corp
PGPORT=443
PGDATABASE=mcp
PGUSER=rag_admin
PGPASSWORD=rag_password
PGSSLMODE=require

# Embedding mode: bm25 | ollama | openrouter
EMBEDDING_MODE=bm25

# Ollama (solo si EMBEDDING_MODE=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=bge-m3:latest

# OpenRouter (solo si EMBEDDING_MODE=openrouter)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=nomic-ai/nomic-embed-text-v1.5

# Dimension del embedding (debe coincidir con el modelo)
EMBEDDING_DIM=1024

# Transport (stdio or http)
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=3011
